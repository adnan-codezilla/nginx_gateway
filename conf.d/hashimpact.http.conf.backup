# =============================================================
#  hashimpact.io  +  api.hashimpact.io
#
#  Stage 1 (no cert yet):
#    - Serves ACME challenge so certbot can issue the cert.
#    - Forwards everything else over plain HTTP so the site
#      stays reachable before SSL is set up.
#
#  After running  issue_all_ssl.sh  this file is replaced with
#  the HTTPS version that lives in
#  conf.d/hashimpact.ssl.conf.disabled
# =============================================================

# ---------- hashimpact.io ----------
server {
  listen 80;
  server_name hashimpact.io;

  # Let's Encrypt ACME challenge (needed to issue / renew certs)
  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    set $hashimpact_frontend http://hashimpact_frontend:8081;
    proxy_pass         $hashimpact_frontend;
    proxy_set_header   Host              $host;
    proxy_set_header   X-Real-IP         $remote_addr;
    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header   X-Forwarded-Proto $scheme;
  }
}

# ---------- api.hashimpact.io ----------
server {
  listen 80;
  server_name api.hashimpact.io;

  location /.well-known/acme-challenge/ {
    root /var/www/certbot;
  }

  location / {
    set $hashimpact_backend http://hashimpact_backend:8080;
    proxy_pass         $hashimpact_backend;
    proxy_set_header   Host              $host;
    proxy_set_header   X-Real-IP         $remote_addr;
    proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header   X-Forwarded-Proto $scheme;
    client_max_body_size 20m;
  }
}
